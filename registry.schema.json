{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/boadij/pi/registry.schema.json",
  "title": "Pi registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "homepage",
    "description",
    "items"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "displayName",
        "type",
        "summary",
        "category",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "extension",
            "skill"
          ]
        },
        "repo": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "install": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "experimental",
            "deprecated"
          ]
        }
      },
      "oneOf": [
        {
          "required": [
            "repo",
            "install"
          ]
        },
        {
          "required": [
            "path"
          ]
        }
      ]
    }
  }
}
